# Rust build output
/target/

# Backup files generated by rustfmt
**/*.rs.bk

# Cargo lock file
# Keep Cargo.lock for applications/binaries.
# Ignore Cargo.lock only for libraries if you want.
# /Cargo.lock

# Environment files
.env
.env.*
!.env.example

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Editor / IDE files
.vscode/
.idea/

# Local temporary files
*.tmp
*.swp
*.swo

# Generated binaries
*.exe
*.dll
*.so
*.dylib

# If you manually copy compiled binary to project root add your binary name 
